{
  "dashboard": {
    "title": "AutoTriage",
    "panels": [
      {
        "title": "Request rate",
        "type": "graph",
        "targets": [
          {
            "expr": "sum by (job) (rate(flask_http_request_total[5m]))",
            "legendFormat": "{{job}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "Error rate (5xx)",
        "type": "graph",
        "targets": [
          {
            "expr": "sum by (job) (rate(flask_http_request_total{status=~\"5..\"}[5m]))",
            "legendFormat": "{{job}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "title": "Latency p99",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum by (job, le) (rate(flask_http_request_duration_seconds_bucket[5m])))",
            "legendFormat": "{{job}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      }
    ],
    "schemaVersion": 16,
    "version": 2
  }
}
