{
  "dashboard": {
    "title": "AutoTriage",
    "panels": [
      {
        "title": "Request rate",
        "type": "graph",
        "targets": [{"expr": "rate(http_requests_total[5m])", "legendFormat": "{{service}}"}],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "Error rate",
        "type": "graph",
        "targets": [{"expr": "rate(http_requests_total{status=~\"5..\"}[5m])", "legendFormat": "{{service}}"}],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "title": "Latency p99",
        "type": "graph",
        "targets": [{"expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "{{service}}"}],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      }
    ],
    "schemaVersion": 16,
    "version": 1
  }
}
