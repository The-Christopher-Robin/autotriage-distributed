# Rendered by render_prometheus.sh; template uses ${VM2_IP}.
global:
  scrape_interval: 15s
scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]
  - job_name: "otel-collector"
    static_configs:
      - targets: ["otel-collector:8889"]
  - job_name: "gateway"
    static_configs:
      - targets: ["gateway:8000"]
  - job_name: "orders"
    static_configs:
      - targets: ["${VM2_IP}:8000"]
    metrics_path: /metrics
  - job_name: "payments"
    static_configs:
      - targets: ["${VM2_IP}:8001"]
    metrics_path: /metrics
  - job_name: "node_exporter"
    static_configs:
      - targets: ["${VM2_IP}:9100"]
